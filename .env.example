# Next.js
NEXT_PUBLIC_APP_NAME="Minilemon Vendor Dashboard"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/minilemon
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/minilemon

# Auth.js (NextAuth v5)
AUTH_SECRET=change-me-32-chars-random-string-via-openssl
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Storage (S3 or Cloudflare R2)
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=minilemon
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_PUBLIC_URL=https://files.minilemon.id

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM="Minilemon <noreply@minilemon.id>"
EMAIL_REPLY_TO=hello@minilemon.id

# Company defaults
COMPANY_NAME="PT. Minilemon Kreasi Indonesia"
COMPANY_ADDRESS="Jalan Mulyosari Timur No 42 Surabaya"
COMPANY_PHONE="+62 895-3341-10951"
COMPANY_EMAIL=hello@minilemon.id
COMPANY_DIRECTOR_NAME="Gersom Halsamer"
COMPANY_DIRECTOR_TITLE="Direktur Utama"
